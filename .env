# ============================================================
#  ComercioTech — Variables de Entorno
#  IMPORTANTE: Este archivo NO debe subirse a repositorios.
#  Contiene credenciales sensibles de la aplicación.
# ============================================================

# Puerto en que corre el servidor
PORT=3000

# URI de conexión a MongoDB
# Sin autenticación (desarrollo local):
MONGO_URI=mongodb://localhost:27017/comerciotech_db

# Con autenticación (producción en VM — descomentar):
# MONGO_URI=mongodb://adminCT:ComercioTech2024!@localhost:27017/comerciotech_db?authSource=admin

# Nombre de la base de datos
DB_NAME=comerciotech_db
